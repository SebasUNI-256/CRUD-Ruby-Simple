<div class="container">
  <h1><%= @product.name %></h1>

  <div class="product-card product-card-stacked">
    <div class="product-info">
      <p><strong>Descripcion:</strong> <%= @product.description %></p>
      <p><strong>Precio:</strong> <%= @product.price %></p>
      <p><strong>Stock:</strong> <%= @product.stock %></p>
      <p><strong>Categoria:</strong> <%= @product.category %></p>
      <p><strong>Activo:</strong> <%= @product.active ? "Si" : "No" %></p>
    </div>
  </div>

  <div class="product-actions">
    <a class="btn" href="/products">Volver</a>
    <a class="btn" href="/products/<%= @product.id %>/edit">Editar</a>
  </div>
</div>

<!--Esto depende del controlador de show-->
